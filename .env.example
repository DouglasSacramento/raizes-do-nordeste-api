# ==========================================
# EXEMPLO DE VARIÁVEIS DE AMBIENTE (.env)
# Copie este arquivo, renomeie para .env e
# preencha os valores sensíveis.
# ==========================================

# Banco de Dados (PostgreSQL via Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=raizesdonordestedb
DB_USER=postgres
DB_PASS=postgres

SPRING_DATASOURCE_DRIVERCLASSNAME=org.postgresql.Driver

# Hibernate e JPA
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

# Segurança JWT
# Substitua o valor de JWT_SECRET por uma chave segura no seu .env local
JWT_SECRET=coloque_sua_chave_secreta_aqui
JWT_EXPIRATION=7200000

# Flyway
SPRING_FLYWAY_ENABLED=true

# Swagger / OpenAPI
SPRINGDOC_APIDOCS_ENABLED=true
SPRINGDOC_SWAGGERUI_ENABLED=true